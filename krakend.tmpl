{
  "$schema": "https://www.krakend.io/schema/krakend.json",
  "version": 3,
  "name": "Core Gateway",
  "timeout": "300s",
  "port": 8080,
  "cache_ttl": "300s",
  "extra_config": {{ marshal .service.extra_config }},
  "endpoints": [
    {{ range $idx, $endpoint := .backend.endpoints }}
      {{if $idx}},{{end}}
      {{ template "backend.tmpl" $endpoint }}
    {{ end }}
  ]
}
