{
  "extra_config": {
    "github_com/devopsfaith/krakend-gologger": {
      "level": "DEBUG",
      "prefix": "[KRAKEND]",
      "syslog": false,
      "stdout": true
    },
    "github_com/devopsfaith/krakend-health": {
      "endpoint": "/__health"
    },
    "security/cors": {
      "allow_origins": ["*"],
      "allow_credentials": true,
      "allow_methods": ["GET", "POST", "OPTIONS", "PUT", "DELETE", "PATCH"],
      "allow_headers": [
        "Content-Type",
        "Authorization",
        "User-Agent",
        "Accept",
        "Referer",
        "Origin",
        "Organization-Id",
        "Project-Id"
      ],
      "max_age": "24h"
    }
  }
}
